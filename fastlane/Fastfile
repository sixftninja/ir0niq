default_platform(:ios)

# ─── Shared helpers ──────────────────────────────────────────────────────────


def xcode_auth_xcargs
  [
    "DEVELOPMENT_TEAM=#{ENV['TEAM_ID']}",
    "CODE_SIGN_STYLE=Automatic",
    "CODE_SIGNING_REQUIRED=YES",
    "CODE_SIGNING_ALLOWED=YES",
    "-allowProvisioningUpdates",
    "-authenticationKeyPath #{File.expand_path(ENV['APP_STORE_CONNECT_API_KEY_PATH'])}",
    "-authenticationKeyID #{ENV['APP_STORE_CONNECT_API_KEY_ID']}",
    "-authenticationKeyIssuerID #{ENV['APP_STORE_CONNECT_API_ISSUER_ID']}"
  ].join(" ")
end

def api_key
  app_store_connect_api_key(
    key_id:       ENV["APP_STORE_CONNECT_API_KEY_ID"],
    issuer_id:    ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
    key_filepath: File.expand_path(ENV["APP_STORE_CONNECT_API_KEY_PATH"])
  )
end

# ─── Platform lanes ──────────────────────────────────────────────────────────

platform :ios do

  # ── Test ─────────────────────────────────────────────────────────────────

  desc "Run unit tests on simulator (no device needed)"
  lane :test do
    run_tests(
      scheme: "Ironiq",
      devices: ["iPhone 17 Pro"],
      clean: true,
      code_coverage: false,
      only_testing: "IroniqTests",
      xcargs: 'CODE_SIGN_IDENTITY="" CODE_SIGNING_REQUIRED=NO CODE_SIGNING_ALLOWED=NO'
    )
  end

  desc "Run unit tests on connected iPhone 15 Pro"
  lane :test_device do
    run_tests(
      scheme: "Ironiq",
      destination: "id=00008130-001404EA3ED1001C",
      clean: true,
      code_coverage: false,
      only_testing: "IroniqTests",
      xcargs: "DEVELOPMENT_TEAM=#{ENV['TEAM_ID']} -allowProvisioningUpdates CODE_SIGNING_REQUIRED=YES CODE_SIGNING_ALLOWED=YES CODE_SIGN_STYLE=Automatic CODE_SIGN_IDENTITY='Apple Development'"
    )
  end

  desc "Run UI tests on connected iPhone 15 Pro"
  lane :test_ui do
    run_tests(
      scheme: "Ironiq",
      destination: "id=00008130-001404EA3ED1001C",
      clean: false,
      code_coverage: false,
      only_testing: "IroniqUITests",
      xcargs: "DEVELOPMENT_TEAM=#{ENV['TEAM_ID']} -allowProvisioningUpdates CODE_SIGNING_REQUIRED=YES CODE_SIGNING_ALLOWED=YES CODE_SIGN_STYLE=Automatic CODE_SIGN_IDENTITY='Apple Development'"
    )
  end

  desc "Run watchOS tests"
  lane :test_watch do
    run_tests(
      scheme: "IroniqWatch",
      devices: ["Apple Watch Series 11 (46mm)"],
      clean: true,
      xcargs: 'CODE_SIGN_IDENTITY="" CODE_SIGNING_REQUIRED=NO CODE_SIGNING_ALLOWED=NO'
    )
  end

  # ── Build ────────────────────────────────────────────────────────────────

  desc "Archive a Release build (no upload). Produces Ironiq.ipa in ./build/"
  lane :build do
    build_app(
      scheme: "Ironiq",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "Ironiq.ipa",
      xcargs: xcode_auth_xcargs,
      export_options: {
        method: "app-store-connect",
        teamID: ENV["TEAM_ID"],
        signingStyle: "automatic"
      }
    )
  end

  # ── Beta ─────────────────────────────────────────────────────────────────

  desc "Build and upload to TestFlight"
  lane :beta do
    ENV["APP_STORE_CONNECT_API_KEY_PATH"] = File.expand_path(ENV["APP_STORE_CONNECT_API_KEY_PATH"])
    key = api_key

    increment_build_number(xcodeproj: "Ironiq.xcodeproj")

    build_app(
      scheme: "Ironiq",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "Ironiq.ipa",
      xcargs: xcode_auth_xcargs,
      export_options: {
        method: "app-store-connect",
        teamID: ENV["TEAM_ID"],
        signingStyle: "automatic"
      }
    )

    upload_to_testflight(
      api_key: key,
      skip_waiting_for_build_processing: true,
      distribute_external: false,
      notify_external_testers: false,
      changelog: "New Ironiq beta build."
    )

    slack_notify_if_configured(message: "Ironiq beta uploaded to TestFlight!")
  end


  desc "Distribute an existing TestFlight build"
  lane :distribute_beta do |options|
    ENV["APP_STORE_CONNECT_API_KEY_PATH"] = File.expand_path(ENV["APP_STORE_CONNECT_API_KEY_PATH"])
    key = api_key

    upload_to_testflight(
      api_key: key,
      distribute_only: true,
      app_identifier: "com.ir0niq.app",
      app_platform: "ios",
      app_version: options[:version] || "1.0",
      build_number: options[:build_number],
      distribute_external: false,
      notify_external_testers: false
    )
  end

  # ── Release ──────────────────────────────────────────────────────────────

  desc "Build and submit to App Store"
  lane :release do
    ENV["APP_STORE_CONNECT_API_KEY_PATH"] = File.expand_path(ENV["APP_STORE_CONNECT_API_KEY_PATH"])
    key = api_key

    increment_build_number(xcodeproj: "Ironiq.xcodeproj")

    build_app(
      scheme: "Ironiq",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "Ironiq.ipa",
      xcargs: xcode_auth_xcargs,
      export_options: {
        method: "app-store-connect",
        teamID: ENV["TEAM_ID"],
        signingStyle: "automatic"
      }
    )

    deliver(
      api_key: key,
      force: true,
      skip_screenshots: true,
      skip_metadata: false,
      submit_for_review: false,    # manual submit after metadata review
      metadata_path: "./fastlane/metadata",
      precheck_include_in_app_purchases: false
    )

    slack_notify_if_configured(message: "Ironiq submitted to App Store!")
  end

  # ── Metadata sync ────────────────────────────────────────────────────────

  desc "Push App Store metadata without a build"
  lane :metadata do
    deliver(
      api_key: api_key,
      skip_binary_upload: true,
      skip_screenshots: true,
      force: true,
      metadata_path: "./fastlane/metadata"
    )
  end

  # ── Private helpers ──────────────────────────────────────────────────────

  private_lane :slack_notify_if_configured do |options|
    next unless ENV["SLACK_URL"]
    slack(message: options[:message], slack_url: ENV["SLACK_URL"])
  end

end
